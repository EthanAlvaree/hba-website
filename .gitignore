# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
desktop.ini
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# unsorted images — kept locally for review, not deployed
public/images/_unsorted/

# Clip Studio Paint source files — editable .clip files are huge
# (often 100+ MB) and not deliverables. Export to JPG/PNG into
# image-originals/ instead and commit those.
*.clip

# Gradelink migration source data — contains student PII (names,
# addresses, phones, parents). Stays on Ethan's machine only.
hba gradelink migration/

# Scratch outputs from migration recon / matching scripts. These
# echo back the same PII so they also stay local.
scripts/.recon-*.txt
scripts/.gradelink-*.md
scripts/.gradelink-*.csv
scripts/.gradelink-*.json
